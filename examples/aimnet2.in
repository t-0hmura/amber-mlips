1il4 ligand QM/MM MD with AIMNet2 (50 steps)
 &cntrl
  imin=0,            ! Run molecular dynamics (no minimization)
  irest=0,           ! Do NOT restart, start new simulation
  ntx=1,             ! Read coordinates only, no velocities
  dt=0.0005,         ! Time step in ps (0.5 fs)
  nstlim=50,         ! Number of MD steps
  ntc=1, ntf=1,      ! No SHAKE bond constraints; compute all interactions
  ig=-1,             ! Random seed from current date and time
  cut=12.0,          ! Nonbonded cutoff in Angstroms
  ntb=2,             ! Periodic boundary with constant pressure
  ntp=1,             ! Isotropic pressure scaling
  ntpr=10,           ! Print energy info every 10 steps
  ntwr=500,          ! Write restart file every 500 steps
  ntwx=10,           ! Write coordinates to trajectory every 10 steps
  ntt=3,             ! Langevin thermostat
  gamma_ln=1.0,      ! Langevin collision frequency (ps^-1)
  temp0=300.0,       ! Target temperature (K)
  ioutfm=1,          ! NetCDF format for trajectory output
  iwrap=1,           ! Wrap coordinates into primary box
  nmropt=0,          ! No NMR restraints
  ifqnt=1,           ! Enable QM/MM
 /
 &qmmm
  qmmask="@1257-1289,1457-1470,1912-1926,2668-2680,2740-2744,2786-2803,4199-4215", ! QM region atom mask
  qmcharge=0,        ! Net charge of QM region
  spin=1,            ! Spin multiplicity of QM region
  qm_theory='aimnet2', ! QM method (amber-mlips backend)
  ml_keywords='--model aimnet2', ! amber-mlips backend options
  qmshake=0,         ! No SHAKE on QM region bonds
  qmcut=12.0,        ! QM/MM electrostatic cutoff (Angstroms)
 /
