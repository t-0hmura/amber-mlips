Alanine dipeptide QM/MM MD with MACE
 &cntrl
  imin   = 0,
  irest  = 1,
  ntx    = 5,
  cut    = 9999.9,
  dt     = 0.0005,
  ntb    = 0,
  ntt    = 0,
  ntpr   = 1,
  ntwx   = 1,
  ntwr   = 5,
  nstlim = 5,
  nscm   = 0,
  ioutfm = 1,
  ntxo   = 1,
  ifqnt  = 1,
 /
 &qmmm
  qmmask=':2',
  qmcharge=0,
  spin=1,
  qm_theory='mace',
  ml_keywords='--model mace-mp-0-large',
  qmshake=0,
  qm_ewald=0,
  qm_pme=0,
 /
