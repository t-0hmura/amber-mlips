ML-only NVT MD with UMA (all atoms computed by MLIP, no MM)
 &cntrl
  imin=0,            ! Run molecular dynamics
  irest=0,           ! New simulation (no velocities in coordinate file)
  ntx=1,             ! Read coordinates only
  dt=0.001,          ! Time step in ps (1 fs)
  nstlim=50,         ! Number of MD steps
  ntc=1, ntf=1,      ! No SHAKE; compute all interactions
  ig=-1,             ! Random seed
  cut=3.0,           ! Dummy small value (ML computes all forces; MM cutoff unused)
  ntb=1,             ! Periodic boundary, constant volume (NVT)
  ntp=0,             ! No pressure control (NVT)
  ntpr=10,           ! Print energy every 10 steps
  ntwr=500,          ! Write restart every 500 steps
  ntwx=10,           ! Write trajectory every 10 steps
  ntt=3,             ! Langevin thermostat
  gamma_ln=5.0,      ! Langevin collision frequency (ps^-1)
  temp0=300.0,       ! Target temperature (K)
  ioutfm=1,          ! NetCDF trajectory format
  iwrap=1,           ! Wrap coordinates into primary box
  ifqnt=1,           ! Enable QM/MM (EXTERN interface)
 /
 &qmmm
  qmmask='@*',       ! ALL atoms → pure ML MD (no MM forces)
  qmcharge=0,        ! Net charge of entire system (must be 0 for ML-only)
  spin=1,            ! Spin multiplicity
  qm_theory='uma',   ! MLIP backend
  ml_keywords='--model uma-s-1p1 --uma-task omat', ! PBC-aware model (omat task)
  qmshake=0,         ! No SHAKE on ML atoms (=all atoms)
  qmcut=0.0,         ! No QM/MM cutoff (all atoms are QM)
 /
