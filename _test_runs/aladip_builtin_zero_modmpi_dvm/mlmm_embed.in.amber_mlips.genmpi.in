  qmmask=':2',
  qmcharge=0,
  spin=1,
  qm_theory='EXTERN',
  qm_ewald=0,
  qm_pme=0,
  qmcut=11.5,
  qmgb=0,
 /


&genmpi
  method='AIMNET2',
  basis='MLIP',
  ntpr=1,
  debug=0,
  dipole=0,
/
